&lt;img alt="" height="3384" referrerpolicy="no-referrer" src="https://images.squarespace-cdn.com/content/v1/5e949a92e17d55230cd1d44f/64447bb8-9674-4bc2-a9da-9a61735f8d2e/Untitled+5.png?format=1000w" width="3384"/&gt;
&lt;/a&gt;
&lt;/figure&gt;
&lt;a href="https://basicappleguy.com/store/p/topographic-amoeba"&gt;
&lt;img alt="" height="1000" referrerpolicy="no-referrer" src="https://images.squarespace-cdn.com/content/v1/5e949a92e17d55230cd1d44f/32940ea4-ec77-4990-8347-c1aaade2ac2f/DD+2.png?format=1000w" width="1000"/&gt;
&lt;/a&gt;
