    &lt;graphic src="https://media.beehiiv.com/cdn-cgi/image/fit=scale-down,quality=80,format=auto,onerror=redirect/uploads/asset/file/41e961ca-df1b-4c88-8da5-5526c1971382/image.png"/&gt;
