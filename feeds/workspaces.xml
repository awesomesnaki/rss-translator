    &lt;graphic src="https://media.beehiiv.com/cdn-cgi/image/fit=scale-down,quality=80,format=auto,onerror=redirect/uploads/asset/file/5c9d90bc-067b-432d-8b7c-5749aa8bb7e0/image.png"/&gt;
