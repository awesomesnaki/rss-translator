    &lt;ul&gt;
      &lt;li&gt;
        &lt;p class="dream-post-content-paragraph j6zgbu1"&gt;Tweetbot&lt;/p&gt;
      &lt;/li&gt;
      &lt;li&gt;
        &lt;p class="dream-post-content-paragraph j6zgbu1"&gt;Sublime Text&lt;/p&gt;
      &lt;/li&gt;
      &lt;li&gt;
        &lt;p class="dream-post-content-paragraph j6zgbu1"&gt;VS Code&lt;/p&gt;
